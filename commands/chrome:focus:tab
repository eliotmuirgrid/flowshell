chrome:focus:tab() {
   arg:check 1 "$@" || return;

   osascript "$1" <<'APPLESCRIPT'
on run argv
   set needle to item 1 of argv

   tell application "Google Chrome"
      repeat with w in windows
         set i to 1
         repeat with t in tabs of w
	    log "Tab: " & tabTitle
            if (title of t as string) contains needle then
               set active tab index of w to i
               set index of w to 1
               activate
               return
            end if
            set i to i + 1
         end repeat
      end repeat
   end tell

   error "No Chrome tab found with title containing: " & needle
end run
APPLESCRIPT
}
