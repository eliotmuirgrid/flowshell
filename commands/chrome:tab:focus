chrome:tab:focus() {
   arg:check 1 "$@" || return;
   local needle="$1"
   echo "Looking for $needle"
   osascript "$needle" <<'APPLESCRIPT'
on run argv
   set needle to item 1 of argv

   tell application "Google Chrome"
      repeat with w in windows
         set i to 1

         repeat with t in tabs of w
            set tabTitle to title of t as string

            if tabTitle contains needle then
               set active tab index of w to i
               set index of w to 1
               activate
               return "Focused: " & tabTitle
            end if

            set i to i + 1
         end repeat
      end repeat
   end tell

   return "No tab found containing: " & needle
end run
APPLESCRIPT
}
