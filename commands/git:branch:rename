git:branch:rename() {
    local new_name="$1"

    if [[ -z "$new_name" ]]; then
        echo "Usage: git:branch:rename <new-branch-name>"
        return 1
    fi

    local old_name
    old_name="$(git:branch)"

    git branch -m "$new_name" || return 1
    git push origin -u "$new_name" || return 1
    git push origin --delete $old_name

    echo "Renamed $old_name -> $new_name"
}
