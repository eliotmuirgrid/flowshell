press:url() {
   arg:check 1 "$@" || return;

   local file="${1:-i}"
   local url

   url="$(md:path "$file")"
   url="$(filter:trim:begin "$url" "/press")"
   url="$(filter:trim:end "$url" ".md")"
   case "$url" in
    */i)
        url="${url%i}"
        ;;
   esac
   echo "https://interfaceware.com${url}"
}
