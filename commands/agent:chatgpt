agent:chatgpt() {
    local key=$(key:get chatgpt)

    #echo "DEBUG: key length = ${#key}" >&2
    #echo "DEBUG: prompt = $*" >&2

    local response

    response=$(curl -s https://api.openai.com/v1/responses \
        -H "Authorization: Bearer $key" \
        -H "Content-Type: application/json" \
        -d "{\"model\":\"gpt-4.1\",\"input\":\"$*\"}")

    echo "DEBUG: raw response:" >&2

    response= filter:trim:begin "\"text\": \";

    echo "DEBUG: $response"
}
