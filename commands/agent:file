agent:file() {
   local agent="$1"
   local file="$2"
   local prompt="$3"

   local cprompt

   if [[ ! -f "$file" ]]; then
      echo "agent:file: '$file' not found" >&2
      return 1
   fi

   echo "$agent $file $prompt"
   cprompt="$(json:escape $prompt:$(file:read $file))"

   echo $cprompt
 #   echo "$(agent:$agent $cprompt)"   
