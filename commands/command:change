command:change() {
    local comment="$*"

    if [[ -z "$comment" ]]; then
        echo "Usage: command:change <comment>"
        return 1
    fi

    (
        cd "$HOME/command" || exit 1

        git add -A || exit 1
        git commit --quiet -m "$comment" || exit 1
        git push --quiet || exit 1
    ) || return 1

    echo "$comment"
}
