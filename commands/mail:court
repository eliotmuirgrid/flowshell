mail:court() {
   local text=$(arg:get text Hello "$@")
   local voice=$(arg:get voice amy "$@")
   local speed=$(arg:get speed 1 "$@")

   echo "Using $voice (speed=$speed) saying $text";

   speak:piper text="$text" voice=$voice speed=$speed play=false 
   mail:prepare to=FamilyTrialOffice-SCJ-Toronto@ontario.ca cc=Toronto.SCJ.Familyintake@ontario.ca subject="RE: Muir v Muir; Court File No. FS-25-00049704-0000" body=$text attachment=output.wav
   afplay output.wav
   rm output.wav
} 
